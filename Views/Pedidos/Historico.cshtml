@model IEnumerable<Restaurante.Models.Pedido>
@using Restaurante.Models

@{
    ViewData["Title"] = "Histórico";
}

<div class="container mt-5">
    <h2 class="mb-4">Histórico de Pedidos Finalizados</h2>

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Cliente</th>
                <th>Mesa</th>
                <th>Produto</th>
                <th>Qtd</th>
                <th>Total</th>
                <th>Data/Hora</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in Model)
            {
                var produto = MockPedidosRepository.Produtos.FirstOrDefault(p => p.Id == pedido.ProdutoId);
                var total = produto != null ? produto.Preco * pedido.Quantidade : 0;

                <tr>
                    <td>@pedido.Id</td>
                    <td>@pedido.NomeSolicitante</td>
                    <td>@pedido.Mesa</td>
                    <td>@(produto != null ? produto.Nome : "-")</td>
                    <td>@pedido.Quantidade</td>
                    <td>@total.ToString("C")</td>
                    <td>@pedido.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                    <td><span class="badge bg-success">@pedido.Status</span></td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <p class="text-muted">Nenhum pedido finalizado ainda.</p>
    }
</div>