@model IEnumerable<Restaurante.Models.Pedido>
@using Restaurante.Models

@{
    ViewData["Title"] = "Todos os Pedidos";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Pedidos</h2>
        <a asp-action="Criar" class="btn btn-primary">Lançar Novo Pedido</a>
    </div>

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Cliente</th>
                <th>Mesa</th>
                <th>Produto</th>
                <th>Tipo</th>
                <th>Qtd</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in Model)
            {
                var produto = MockPedidosRepository.Produtos.FirstOrDefault(p => p.Id == pedido.ProdutoId);

                var corBadge = pedido.Status switch
                {
                    StatusPedido.Preparando => "bg-warning text-dark",
                    StatusPedido.Pronto => "bg-info text-dark",
                    StatusPedido.Entregue => "bg-success",
                    _ => "bg-secondary"
                };

                <tr>
                    <td>@pedido.Id</td>
                    <td>@pedido.NomeSolicitante</td>
                    <td>@pedido.Mesa</td>
                    <td>@(produto != null ? produto.Nome : "Produto não encontrado")</td>
                    <td>@(produto != null ? produto.Tipo.ToString() : "-")</td>
                    <td>@pedido.Quantidade</td>
                    <td>
                        <span class="badge @corBadge">@pedido.Status</span>
                    </td>
                    <td>
                        @if (pedido.Status != StatusPedido.Entregue)
                        {
                            <form asp-action="AtualizarStatus" asp-route-id="@pedido.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                    Avançar Status
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">Finalizado</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>